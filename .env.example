PORT=3000
HOST_NAME=http://localhost
MONGODB_URI=mongodb://localhost:27017/the_other_wife
NODE_ENV=development
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me_too
# Web OAuth client id (required). Android/iOS are optional extra audiences —
# only needed if the mobile app signs in using a platform-specific client id.
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
CORS_ORIGIN=http://localhost:3000
RESEND_API_KEY=
FROM=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EXPO_ACCESS_TOKEN=
FRONTEND_URL=http://localhost:3000
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
# Default radius (km) for location-based meal/vendor search when a customer
# does not pass an explicit `radius` query param. Clamped per-request to 1-100.
SEARCH_RADIUS_KM=25
